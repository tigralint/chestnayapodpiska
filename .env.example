# --- Client-side Configuration (Vite) ---
VITE_TURNSTILE_SITE_KEY=0x4AAAAAA...your_site_key

# --- Server-side Configuration (Vercel Functions) ---

# Google Gemini API for LLM generation (Gemma 4 31B-IT primary, Gemini Flash fallback)
GEMINI_API_KEY=AIzaSy...your_key

# Cloudflare Turnstile Secret
TURNSTILE_SECRET_KEY=0x4AAAAAA...your_secret_key

# Upstash Redis for Rate Limiting and Analytics
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...your_token

# HMAC secret for anonymizing IP addresses (hashIp)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_HASH_SECRET=your_random_secret_here

# --- Notification Services (Optional / Internal) ---

# Telegram Bot API (For developer alerts and feedback)
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...

# Telegram Webhook Secret (set via setWebhook API, verifies incoming requests)
# TELEGRAM_WEBHOOK_SECRET=your_random_secret_here
